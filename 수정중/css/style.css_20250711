/*============== 학과정보 ================*/
.sub01_01 {clear: both; font-size:16px;color:#333;width:70%;text-align:center;margin:0 auto;line-height:140%; letter-spacing: -0.5pt; font-family:"NotoKR-Regular", Sans-serif; font-weight: 400;}
.sub01_01 p{font-size:25px;color:#333;font-family:'NotoKR-Medium', sans-serif;font-weight:600;padding-bottom:20px;line-height:140%; letter-spacing: -0.5px; }

.subbg {width:100%;border:1px dashed #ddd;padding: 50px 0; text-align:center !important; background: #f5f5f5;}

.bot{width:100%;border-top:1px dashed #ddd;margin:50px auto;text-align:center !important;}
.bot div{display:inline-block;margin-left:-25px;}
.bot .bo{ margin: 0 auto; display: inline-block;}
.bot div div:nth-child(1){margin-left:25px;}
.bot p{margin-top:40px;padding-bottom:20px;font-size:25px;color:#274992;font-family:'NotoKR-Medium', sans-serif;font-weight:600;letter-spacing: -0.5px; }
.bot p:before { content:''; display:block; position:relative; left:0; right:0; top:0px; width:35px; height:3px; margin:0 auto; background:#274992;border-radius: 50px;  }
.sub01_02{width:250px;height:250px;opacity: 0.90; border-radius:125px;display:inline-block;color:#fff;float:left;}
.sub01_02 span{width:170px;display:inline-block;font-size:13px;LETTER-SPACING: -0.9px;font-family:"NotoKR-Regular", Sans-serif; font-weight: 400; }
.sub01_02 strong{width:170px;font-size:20px;max-height: 20px; line-height: 120%; letter-spacing: -2pt; padding-top:40px;display:inline-block; font-family:"NotoKR-Regular", Sans-serif; font-weight: 400;padding-bottom:30px}
/*.sub01_02 strong:before { content:''; display:block; position:relative; left:0; right:0; top:40px; width:20px; height:3px; margin:0 auto; background:#fff;border-radius: 50px;  }*/
.bg1{background-color:#f05333;}
.bg2{background-color:#f39800;}
.bg3{background-color:#9cb227;}
.bg4{background-color:#219dcb;}
.bg5{background-color:#ae5da1;}
.bg6{background-color:#888888;}

.Human{width:100%;padding-top:0px;border-top:1px dashed #ddd;margin-bottom:40px;text-align:center;}
.Human p{margin-top:40px;padding-bottom:30px;font-size:25px;color:#274992;font-family:'NotoKR-Medium', sans-serif;font-weight:600;letter-spacing: -0.5px; }
.Human p:before { content:''; display:block; position:relative; left:0; right:0; top:0px; width:35px; height:3px; margin:0 auto; background:#274992;border-radius: 50px;  }
.Human div{margin:0 auto;display:inline-block;}
.Human div div{margin-left:20px;margin-bottom:20px}
.sub01_03{width:333px;color:#fff;float:left;background-color:#1e4faf; border-radius:7px;padding-bottom:20px }
.sub01_03 span{padding-top:7px;padding-bottom:7px;display:inline-block;font-size:14px;width:90%; background-color:#FFF;color:#4a4a4a;line-height:180%;letter-spacing: -0.5pt; margin-bottom:7px; border-radius:6px;text-align:left;padding-left:10px;font-family:"NotoKR-Regular", Sans-serif; font-weight: 400;}
.sub01_03 strong{font-size:20px;padding-top:40px;display:inline-block; padding-bottom:0px;width:100%;font-family:"NotoKR-Regular", Sans-serif; font-weight: 400;}
.sub01_03 p{text-align:center;display:block;font-size:18px;padding-bottom:10px;color:#fff;font-family:"NotoKR-Regular", Sans-serif; font-weight: 700;}
.sub01_03 p:before { content:''; display:block; position:relative; left:0; right:0; top:-15px; margin:0 auto;width: 30px; height: 3px; background: #fff;   }
.w1{width:60%}
.w2{width:7%}

