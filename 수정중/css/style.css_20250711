@charset "UTF-8";


/* Layout - Style */

	html, body{height:100%; font-size: 14px;}

	p {line-height: 180%;}
	input[type=text] {line-height: 120%;}

	* html #wrap {height: 100%;}
	#wrap{position:relative;min-width:1200px;min-height:100%;}
	#header{position:relative;z-index:5;}
	#nav{position:absolute;top:62px;left:387px;}
	#aside{position:absolute;right:0;z-index:5;width:131px;}
	#container{position:relative;z-index:10;margin:0 auto;padding-bottom:123px;width:1200px;}
	#content{position:relative;min-height:500px;}
	/*
	#footer{position:relative;margin-top:-84px;width:100%;height:114px;background: url("../images/main/bg_foot.gif") repeat-x left top;}*/


/* //Layout - Style */
/* placeholder 타 브라우저 익스플로러처럼 FOCUS 시 문구 사라지도록 변경 */
input:focus::-webkit-input-placeholder, textarea:focus::-webkit-input-placeholder { /* WebKit browsers */ color:transparent; }
input:focus:-moz-placeholder, textarea:focus:-moz-placeholder { /* Mozilla Firefox 4 to 18 */ color:transparent; }
input:focus::-moz-placeholder, textarea:focus::-moz-placeholder { /* Mozilla Firefox 19+ */ color:transparent; }
input:focus:-ms-input-placeholder, textarea:focus:-ms-input-placeholder { /* Internet Explorer 10+ */ color:transparent; }


/* Header - Style */

	.header{margin:0 auto;position:relative;width:1200px;height:154px;}
	.header h1{padding:50px 0 0 30px;}
	.header .private{position:absolute;top:6px;right:0;}

	.nav{position:relative;}
	.nav ul{display:table;width:100%;}
	.nav ul > li{position:relative;padding:0 90px 0 0;font-size:16px;float:left;height:92px;text-align:center;}
	.nav.manager ul > li{padding-right: 70px;}
	.nav ul > li:hover ol{display:inline-block;}
	.nav ul > li > a{display:block;width:100%;height:41px;font-weight:bold;color:#5c5c5c;}
	.nav ul > li > a:hover{}
	.nav ul > li.on{z-index:1;}
	.nav ul > li > ol{position:absolute;bottom:0;left:-15px;z-index:1;width:365px;display:none;}
	.nav ul > li+li ol{}
	.nav ul > li+li+li ol{left:-200px;width:675px;}
	.nav ul > li+li+li ol.student{left:-10px}
	.nav ul > li+li+li+li ol{left:-15px;margin-left:-28px;width:250px;}
	.nav ul > li ol li{float:left;}
	.nav ul > li ol li a{display:inline-block;padding:0 15px;line-height:34px;color:#fff;font-size:14px;}
	.nav ul > li ol li a:hover{}
	.nav ul > li ol li+li{}
	.nav ul > li ol li.on{font-weight:bold;}

/* //Header - Style */


.lnb-title {
    display: table;
    width: 100%;
    font-size: 20px;
    color: #ffffff;
    background-color: #1e4faf;
	border-bottom: 1px solid #6285c8;
}
.lnb-title > p {
    display: table-cell;
    width: 100%;
    padding: 10px 10px;
    vertical-align: middle;
    height: 60px;
    text-align: center;
}

/* Footer - Style

	.footer{position:relative;margin:0 auto;max-width:1200px;background: url("../images/main/bg_foot.gif") repeat-x left top;}
	.footer .logo{position:absolute;top:30px;left:28px;}
	.footer .copyTxt{padding:40px 0 0 300px;font-size:11px;line-height:16px;color:#434242;width:900px;}
	.footer .mark{position:absolute;top:30px;left:1078px;}

/* //Footer - Style */


/* Common - Style */

	::-webkit-input-placeholder {color: #f00;}
	:-moz-placeholder {color: #f00;}
	::-moz-placeholder {color: #f00;}
	:-ms-input-placeholder {color: #f00;}

	.main-login ::-webkit-input-placeholder {color: #999;}
	.main-login :-moz-placeholder {color: #999;}
	.main-login ::-moz-placeholder {color: #999;}
	.main-login :-ms-input-placeholder {color: #999;}

	.mab0{margin-bottom:0 !important;}

	.noWrap, label {white-space:nowrap;}

	.mainCon{position:relative;}
	.mainCon .guideBtn{position:absolute;top:241px;left:0;}
	.mainCon .visImg{padding-bottom:25px;}
	.mainCon .mainBtm{margin:0 auto;width:1200px;display:table;}
	.mainCon .mainBtm .box{float:left;}
	.mainCon .mainBtm .box+.box{margin-left:40px;}
	.mainCon .mainBtm .box .tit{line-height:32px;text-align:center;color:#fff;background:#4f4f4f;}

	.noticeBox{width:300px;}
	.noticeBox .img{padding:1px 0 0 0;}
	.noticeBox ul.list{padding-top:10px;}
	.noticeBox ul.list li{padding:0 0 5px 8px;width:292px;display:table;background: url("/images/main/ico_dot.gif") no-repeat left 7px;font-size:13px;}
	.noticeBox ul.list li a{color:#666666;}
	.noticeBox ul.list li a span.txt{float:left;display:inline-block;width:213px;height:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
	.noticeBox ul.list li a span.date{padding-left:9px;padding-top:3px;float:right;font-size:11px;color:#666666;letter-spacing:-1px;}
	.noticeBox ul.list li a span strong{font-weight:normal;color:#cccccc;}

	.memberBox{width:230px;}
	.memberBox .mainLogin{position:relative;}
	.memberBox .mainLogin .inp{padding:10px 0;}
	.memberBox .mainLogin .inp p{position:relative;padding-bottom:2px;}
	.memberBox .mainLogin .inp p label{position:relative;}
	.memberBox .mainLogin .inp p label strong{position:absolute;top:4px;left:10px;font-size:11px;color:#999;}
	.memberBox .mainLogin .inp p label input{padding:0 10px;width:138px;font-size:12px;height:22px;line-height:22px;border:1px solid #cccccc;}
	.memberBox .mainLogin .submit{position:absolute;top:10px;right:0;}
	.memberBox .mainLogin .btn{padding-bottom:40px;}
	.memberBox .mainLogin .btn a{float:left;padding-right:2px;}

	/* .memberBox .mainLogin .btn a+a{margin-left:3px;} */

	.mainssologin {width: 230px; height: 50px; background: #3c4863; margin: 10px 0; font-size: 12px; text-align: center;}
	.mainssologin a {display: inline-block; width: 230px; line-height: 50px; color: #fff;}

	.engineBox{width:250px;overflow:hidden;}
	.engineBox ul{margin-top:2px;width:260px;display:table;}
	.engineBox ul li{padding:0 2px 2px 0;float:left;}
	.engineBox ul li+li{}

	.login{position:absolute;top:6px;right:0;}
	.login a{font-size:12px;color:#5c5c5c;font-weight:bold;}
	.login a+a{padding-left:8px;margin-left:6px;}
	.login .campBtn{padding:3px 8px 3px 8px;font-size:11px;background:#4f4f4f;color:#fff;}

	.subCon{padding-top:40px;width:100%;display:table;}
	.subCon .subNav{width:220px;float:left;}
	.subCon .subBox{position:relative;width:910px;float:right;}

	.subCon h2{padding-left: 13px; padding-bottom: 20px; font-size: 26px; color: #333;font-family: 'NotoKR-Medium', sans-serif; font-weight: 500; letter-spacing: -1pt; line-height:130%; background: url(../images/sub/tit_arrow.jpg) left 7px no-repeat;}

	.subCon h3{padding-bottom:5px; font-size:24px; color: #222222; letter-spacing: -0.08em; line-height: 150%; font-family:"NotoKR-Medium", Sans-serif; font-weight: 500;}


	.subCon h3.botPad5 {padding-bottom: 5px;}
	.subCon h4{padding-bottom:10px;font-size:18px;color: #222222;line-height: 150%;font-family:"NotoKR-Regular", Sans-serif;font-weight: 400;}
	.subCon h5{padding-bottom:10px;font-size:16px;color: #222222;line-height: 150%;font-family:"NotoKR-Regular", Sans-serif;font-weight: 400;}

	.subNav{}
	.subNav .tit{width:220px;height:123px;text-align:center;vertical-align:middle;display:table-cell;font-size:24px;font-weight:bold;color:#fff;line-height:36px;}
	.subNav ul{border-top:2px solid #222;border-bottom:1px solid #222;}
	.subNav ul > li+li{border-top: 1px solid #d5d5d5;}
	.subNav ul > li > a{display:inline-block;padding-left:20px;width:200px;line-height:49px;font-size:16px;font-weight:bold;color:#848484;}
	.subNav ul > li > a{
		-webkit-transition:all 0.25s ease;
		-moz-transition:all 0.25s ease;
		-ms-transition:all 0.25s ease;
		-o-transition:all 0.25s ease;
		transition:all 0.25s ease;
	}
	.subNav ul > li.on > a,
	.subNav ul > li:hover > a{padding-left:30px;width:190px;color:#333333;background:#f0f0f0;}
	.subNav ul > li.on > ol{display:inline-block;}
	.subNav ul > li > ol{display:none;padding:15px;width:190px;border-top: 1px solid #d5d5d5;}
	.subNav ul > li > ol li+li{padding-top:5px;}
	.subNav ul > li > ol li a{font-size:13px;color:#333;}
	.subNav ul > li > ol li a{
		-webkit-transition:all 0.25s ease;
		-moz-transition:all 0.25s ease;
		-ms-transition:all 0.25s ease;
		-o-transition:all 0.25s ease;
		transition:all 0.25s ease;
	}
	.subNav ul > li > ol li.on a{font-weight:bold;}
	.subNav ul > li > ol li:hover a{padding-left:10px;font-weight:bold;}

	.subNav ul > li > ol > li > p {display:none;padding-top: 5px; padding-left:15px;width:175px;}
	.subNav ul > li.on > ol > li > p {display:inline-block;}
	.subNav ul > li.on > ol > li > p > a {font-weight: normal;}
	.subNav ul > li > ol > li > p.on > a {font-weight: bold;}


	.bnarBtn{padding-top:20px;}
	.bnarBtn p{padding-bottom:10px;}
	.bnarBtn p a{padding:15px 15px 15px 0;width:205px;display:inline-block;font-size:16px;color:#fff;text-align:center;font-weight:bold;}
	.imgBtn{padding-top:40px;}

	a.basic{display:inline-block;padding:0 10px;font-size:13px;line-height:24px;text-align:center;border-radius:2px;color:#333333;border:1px solid #d5d5d5;background:#f0f0f0;}

	a.sBtn{display:inline-block;width:80%;line-height:24px;text-align:center;color:#fff !important;border-radius:2px;}
	a.cor0{border:1px solid #2a4a70;background:#558ed5;}
	a.cor1{border:1px solid #733634;background:#c0504d;}
	a.cor2{border:1px solid #254c67;background:#00b050;}
	a.cor3{border:1px solid #3e2f07;background:#d4ae44;}
	a.cor4{border:1px solid #fff;}

	.copy{display:inline-block;padding:0 10px;min-width:40px;line-height:24px;font-size:12px;text-align:center;color:#fff !important;border-radius:2px;background:#c0504d;}
	.addBtn{display:inline-block;padding:0 10px;margin-top: 5px; min-width:30px;line-height:24px;font-size:12px;text-align:center;color:#fff !important;border-radius:2px;background:#558ed5;}
	.notBtn{display:inline-block;padding:0 10px;min-width:30px;line-height:24px;font-size:12px;text-align:center;color:#fff !important;border-radius:2px;background:#c0504d;}
	.gtecNotBtn{background:#5f3ec5}
	.ectBtn{display:inline-block;padding:0 10px;min-width:30px;line-height:24px;font-size:12px;text-align:center;color:#fff !important;border-radius:2px;background:#cccccc;}
	.p5{padding:5px 5px !important;}
	.wi50{width:50px !important;}
	.wi80{width:80px !important;}
	.wi120{width:120px !important;}
	.lineh20{line-height:20px !important;}

	.btnBox{padding:15px 0;width:100%;display:table;}
	.btnBox a{display:inline-block;padding:0 15px;min-width:30px;font-size:0.9em;line-height:24px;text-align:center;color:#fff;border-radius:2px;}
	a.btnType0{color:#333333;border:1px solid #d5d5d5;background:#f0f0f0;}
	a.btnType1{color:#fff !important;border:1px solid #d5d5d5;background:#777;}
	a.btnEdit{padding: 1px 2px; margin-left: 5px;}
	a.btnHead{padding: 5px 10px;}

	input[type=text], input[type=password]{width:90%;padding:9px 5px;font-size:13px;border:1px solid #d5d5d5;height:17px;}

 	input[type=file]{width:90%;padding:4px 5px;font-size:13px;border:1px solid #d5d5d5;height:23px;}

	input.inpTxt{height: }
	textarea{width:calc(100% - 20px);height:100px;padding:5px;font-size:13px;border:1px solid #d5d5d5;}
	select{min-width:60px;padding:0 5px;height:35px;font-size:13px;border:1px solid #d5d5d5;}

	p.p {margin:10px 0;}
	p.txt {line-height: 20px;}

	.dot-box, .guide-line, .check-box {background: #f1f1f1; padding: 10px; margin: 0 0 10px 0; border: 2px dotted #aaa; line-height: 160%;}

	.layPop{position:fixed;top:0;left:0;z-index:1100;background:#fff;display:none;border-radius:10px;left:15%;top:15%;width:70%;height:70%;}
	.layPop.full{left:0%;top:0%;width:100%;height:100%}
	.layPop.big{left:2%;top:2%;width:96%;height:96%}
	.layPop .tit{padding:15px 0;text-align:center;color:#fff;font-weight:Bold;background:#000;}
	.layPop .box{padding:15px;}
	.layPop .close{position:absolute;top:15px;right:20px;}
	.layPop .close a{color:#fff;}
	.popBg{position:fixed;top:0;left:0;z-index:1001;width:100%;height:100%;background: url(../images/common/bg_laypop.png) left top;display:none;}

	.loginPop{position:absolute;top:50%;left:50%;margin-left:-300px;margin-top:-345px;padding:90px 0 90px 0;width:600px;background:#fff;border-radius:10px;}
	.loginPop .tit{padding-bottom:55px;text-align:center;}




/* =========== 그래프 ============ */
.area_chart .area_chart_title {
    width: 100%;
    padding: 10px 0;
    background: #003366;
    color: #fff;
    font-weight: 500;
	font-size: 16px; letter-spacing: -0.5pt;
    text-align: center;
	font-family:"NotoKR-Regular", Sans-serif;
}

.area_chart .prin {position: absolute; top: 0px; right: 20px; padding: 3px 20px; font-size: 14px;}
.area_chart .area_chart_img {border: 1px solid #ddd;text-align: center; position: relative; margin-bottom: 10px;}

/* //Commen - Style */
	table th{padding:15px 10px;border-bottom:1px solid #d5d5d5;background:#f6f6f6; border-left:1px solid #dedede; border-right:1px solid #dedede;font-size:14px;color:#222222; }
	table th.color2{background-color: #f5f8ff !important;}
	table td{padding:10px;border-bottom:1px solid #ddd;border-left:1px solid #ddd; border-right:1px solid #ddd;}
	table thead tr:last-child{border-bottom:1px solid #d5d5d5;}
	table tr + tr {border-top:1px solid #d5d5d5;}
	table.tdLine tr td + td, table.tdLine tr th + th{border-left:1px solid #d5d5d5;}

	table.headTbl{width:100%;margin-bottom:20px;border-top:2px solid #222;border-bottom:1px solid #222;}
	table.headTbl tr th{font-size:14px;color:#222222; font-family: 'NotoKR-Medium', sans-serif; font-weight: 500; text-align:center;vertical-align:middle;background:#f6f6f6;}
	table.headTbl tbody tr td{line-height:20px;vertical-align:middle;text-align:center;color:#555555;height:20px;}
	table.headTbl thead tr th, table.headTbl tbody.head tr th{padding:15px 0 15px 0;font-size:14px;color:#222222;vertical-align:middle;border-bottom:1px solid #d5d5d5;background:#f6f6f6; border-left:1px solid #dedede; border-right:1px solid #dedede;}
	table.headTbl tbody tr td ul li {display: inline-block; width:190px; line-height:180%}
	table.headTbl td{padding:12px 5px 12px 5px;font-size:14px;color:#222222;vertical-align:middle;border-bottom:1px solid #ddd;border-left:1px solid #ddd; border-right:1px solid #ddd;}
	table.headTbl tr:hover {background:#fafafa}
	.left{padding-left:10px !important;}
	.leftTextArea {text-align: left !important; word-break: break-all; white-space: pre-wrap;}

/* table.headTbl td p {height: 18px;} */
/* table.headTbl th p {height: 18px;} */

.font_s {font-size: 12px;} 




table .scroll {border-collapse: collapse; width:  100%; overflow-x: scroll; display: block;}

table .scroll tbody {overflow-x: scroll; /*overflow-x: scroll; */overflow-y: hidden;display: block; height: auto;}
table .scroll tbody tr {display: table;}
.font-s{font-size: 0.8em; color: #999;}

.table-responsive-sm {
        display: block;
        width: 100%;
		max-width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch
    }





