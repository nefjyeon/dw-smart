	/* 교과목 NCS 비율 적용*/
	.statsTbl{float:left; padding-left:150px;}
	.statsTbl .bodyTbl{width:350px;}
	.statsBox .statsTbl dl{padding-top:150px;width:378px;}

	/* 교수 검색 Layer */
	.prfsSearch{position:absolute;left:0;top:0;z-index:9999;background:#ffffff;padding:20px;}
	.prfsSearch .tit{padding:10px 0;text-align:center;color:#fff;font-weight:Bold;background:#777;}
	.prfsSearch .tit .close{float:right;padding-right:10px;}
	.prfsSearch .tit .close a{color:#fff;}
	.prfsSearch .search{padding:10px;border-bottom:1px solid #000000;}
	.prfsSearch .searchBody{}
	.prfsSearch .searchBody ul{height:20px;padding-top:10px;border-bottom:1px solid #d5d5d5;}
	.prfsSearch .searchBody ul li{float:left;min-width:160px;font-size:14px;padding-left:20px;}

	ul.ulList {width: 100%;}
	ul.ulList li {font-size: 14px; line-height: 60px; border: 1px solid #999; border-radius: 10px; padding: 0 20px; margin-bottom: 20px; cursor: pointer;}

	ul.modelUl {width: 100%:}
	ul.modelUl li {width: 19%; min-width: 150px; font-size: 14px; min-height: 60px; background: #eee; float: left; margin-left: 10px; margin-bottom: 10px; text-align: center;display:table;}
	ul.modelUl li p {display:table-cell;vertical-align: middle;}
	td.modelOne {text-align:center; background: #eee;}


	.fontAlert {color: #ff0000 !important; line-height: 140%;}
	.fontInfo {color: #0080ff !important; line-height: 140%;}
	.left {text-align: left !important;}
	.rit {text-align: right !important;}
	.center {text-align: center !important;}


	a.btn{display:inline-block; color:#333333; border:1px solid #d5d5d5; border-radius:5px; background:#f0f0f0; padding: 8px 20px; white-space:nowrap; text-align:center;}
	a.low{font-size: 13px; padding: 4px 10px; line-height: 140%;}
	a.hfull{width: 100%;}

	.divArrowBottom {width:100%; height:80px; background:url('/images/common/arrow_bottom.png') no-repeat center;}
	.divArrowTop {width:100%; height:80px; background:url('/images/common/arrow_top.png') no-repeat center;}

	h3 .subScript {position:relative;top:10px;float:right;font-size:13px;font-family:"NotoKR-Regular", Sans-serif; }

	.infoPop {border: 1px dotted #5d5d5d; background: #fffdcf; font-size: 13px; line-height: 20px; padding: 5px 10px; margin-bottom: 15px;}
	.infoPop p {display:inline-block; cursor:pointer}
	.infoPop .infoBtn {float: right; border: 1px solid #999; line-height: 13px; text-align: center; padding: 2px; margin: 2px 0px; margin-left: 10px; cursor: pointer; background: #fcfae2}
	.infoReady {display: none; position: absolute; right: 30px;; cursor: pointer;}

	.tdRowspan {line-height: 48px;}
	.tdRowspan+.tdRowspan {border-top: 1px solid #ddd;}

	.eduDesc{width:100%;height:100px;padding-bottom:15px;}
	.eduDesc textarea {width:100%;height:95%;}
	.eduDescView {margin-bottom:15px;padding:10px;border:2px dotted #999;font-size: 13px;}



	ul.surveyBox {display: block; margin: 10px 20px 20px;}
	ul.surveyBox > li {line-height: 20px; margin-bottom: 5px;}
	ul.surveyBox ul {display: inline-block; margin: 5px 20px 10px; width: 100%;}
	ul.surveyBox ul > li {line-height: 24px;}
	ul.surveyBox ul > li textarea {width: 85%; height: 100px; padding: 10px;}
	ul.surveyBox ul > li input[type=text] {width: 85%;}
	ul.surveyBox li .resultText {background-color: #eee; margin-bottom: 10px; padding: 10px;}
	ul.surveyBox li div.barBg, .surveyResult div.barBg {width: 100%; height: 20px; background-color: #eee;}
	ul.surveyBox li div.barBg > div, .surveyResult div.barBg > div {height: 20px; background-color: #4da91e;}
	ul.surveyBox li div.barBg > div.barBlue, .surveyResult div.barBg > div.barBlue {background-color: #51a6e3;}


	.hintMsg {position: absolute; top: 0; left: 0; display:none; min-width: 100px; max-width: 200px; border: 1px solid #9e9e9e; padding: 10px; border-radius: 5px; background: #000000; font-size: 12px; font-weight: normal; line-height: 160%; color: #fff; white-space:normal; z-index:999999;}
	.hintMsg div.arrow {position: absolute; top: 0; left: -5px; width: 5px; height: 8px; background-image: url('../images/common/msg_arrow.png'); background-position: left top;}
	.hintMsg div.arrow.right {left: auto; right: -5px; background-position: right top;}
	p.ico, span.ico {display:inline-block; padding: 2px; margin-right: 2px; border-radius: 2px; background: #ff5722; font-size: 12px; color: #fff; font-weight: normal; line-height: 100%; white-space:nowrap;}
	p.ico.mid, span.ico.mid {padding: 4px 4px;}
	p.ico.big, span.ico.big {padding: 4px 7px;}
	p.ico.ncs, p.ico.blue, span.ico.ncs, span.ico.blue {background: #2674d5;}
	p.ico.self, p.ico.green, span.ico.self, span.ico.green {background: #7cb737;}
	p.ico.other, p.ico.grey, span.ico.other, span.ico.grey {background: #5b5b5b;}
	p.ico.other, p.ico.lgrey, span.ico.other, span.ico.lgrey {background: #999;}
	p.ico.dblue, span.ico.dblue {background: #193657;}

	p.ico.bigBox, span.ico.bigBox {font-size: 18px; padding: 5px 10px;}

	body.surveyBody {background: #e0e5f1;}
	body.surveyBody div.table-responsive {padding: 20px; background: #fff; border-radius: 15px;}

	.surveySelector, .surveyCheckbox {background-color: #fff; color: #000; text-align: center;}
	.surveySelector.active, .surveyCheckbox {cursor: pointer;}
	.surveySelector.active:hover, .surveyCheckbox.active:hover {background-color: #e0e5f1;}
	.surveySelector.selected, .surveyCheckbox.checked1 {background-color: #6880b0; color: #fff;}

	div.p_b30{padding-bottom:30px;}
}


