/*lnb 영역 - 시작 */
/* lnb-동아-학과 운영계획서.txt */
/* lnb-동아-학과 운영결과보고서.txt */
.lnb-smenu.progress { background-color: #143c8c; }
.lnb-smenu {padding-left: 10px;width: calc(100% - 10px) !important; font-size: 1.1em; display: none !important;font-size: 16px; font-family:"NotoKR-Regular", Sans-serif;color: #fff;}
.lnb-smenu.active{
	display: table !important;
/* 	background-color: #1e4faf; */
	border-bottom: none; 
	}
.lnb-smenu-ico {padding: 15px 0 0 10px; font-size:1.2em;}
.lnb-smenu a {padding-left: 0 !important;display: table-cell; width: 100%; vertical-align: middle; height:50px; text-align: left;}
.lnb-smenu.active a { color: #fff; font-weight: 400; border: none;}
 
.lnb-smenu a p {letter-spacing: -0.1em; font-size: .9em !important;}
.lnb-smenu a .active { color: yellow; font-weight: 500; }
/*lnb 영역 - 끝 */



/*lnb 영역 - 시작 */
/* 3depth menu */
.lnb-Smenu {padding-left: 10px;width: calc(100% - 0px) !important; font-size: 1.1em; display: none !important;}
.lnb-Smenu li {padding-left: 20px !important;}
.lnb-Smenu.active{ display: table !important;}
.lnb-Smenu-ico {padding: 15px 0 0 10px; font-size:1.2em;}
.lnb-Smenu a {padding-left: 0 !important;}
.lnb-Smenu a p {letter-spacing: -0.1em; font-size: .9em !important;}
.lnb-Smenu a .active { color: yellow; font-weight: 500; text-decoration: underline;}


/* =================== lnb-서브 =============== */
.lnb-Smenu {display: none; padding: 0px;font-family:"NotoKR-Regular", Sans-serif; background-color: #19459a;}
.lnb-Smenu .active {display: block; background-color: #19459a; color: #ffff00 !important;  }
.lnb-Smenu .active a{color: #ffff00 !important; }
.lnb-Smenu li {/*position: relative;*/ line-height: 40px;  padding: 10px 0 10px 25px; font-size: 14px; line-height: 120%; border-bottom: 1px solid #1e4ba2;} /*==라인==*/

.lnb-Smenu li.active {}
.lnb-Smenu li a {color: #fff;letter-spacing: -0.5pt; margin-left: 10px; }
.lnb-Smenu li a:hover {color: #ffff00 !important; }
.lnb-Smenu li:hover {background-color: #1e4faf;color: #ffff00 !important;} 

.menuon {display: block !important;}
.lnb div .lnb-Smenu .active{display: block !important;}


/*lnb 영역 - 끝 */



/*lnb 영역 - 시작 */
/* 4depth menu */
.lnb-4Smenu {padding-left: 10px;width: calc(100% - 0px) !important; font-size: 1.1em; display: none !important;}
.lnb-4Smenu li {padding-left: 20px !important;}
.lnb-4Smenu.on{ display: table !important;}
.lnb-4Smenu-ico {padding: 15px 0 0 10px; font-size:1.2em;}
.lnb-4Smenu a {padding-left: 0 !important;}
.lnb-4Smenu a p {letter-spacing: -0.1em; font-size: .9em !important;}
.lnb-4Smenu a .active { color: yellow; font-weight: 500; text-decoration: underline;}


/* =================== lnb-서브 =============== */
.lnb-4Smenu {display: none; padding: 0px;font-family:"NotoKR-Regular", Sans-serif; background-color: #19459a;}
.lnb-4Smenu .active {display: block; background-color: #19459a; color: #ffff00 !important;  }
.lnb-4Smenu .active a{color: #ffff00 !important; }
.lnb-4Smenu li {/*position: relative;*/ line-height: 40px;  padding: 8px 0 8px 25px; font-size: 13px; line-height: 120%; border-bottom: 1px solid #1e4ba2;} /*==라인==*/

.lnb-4Smenu li.active {}
.lnb-4Smenu li a {color: #fff;letter-spacing: -0.5pt; margin-left: 20px; }
.lnb-4Smenu li a:hover {color: #ffff00 !important; }
.lnb-4Smenu li:hover {background-color: #1e4faf;color: #ffff00 !important;} 

.menuon {display: block !important;}
.lnb div .lnb-4Smenu .active{display: block !important;}


/*lnb 영역 - 끝 */





/* 교육품질관리 > 학과 교육품질관리 */
#majorPlan .text-area {
    width:98%;
    box-sizing: border-box;
	height: 100%;
    padding: 10px!important;
	font-family: "NotoKR-Regular", Sans-serif;
}

#majorPlan table.bodyTbl {
	border-top: 3px solid #222 !important;
	border-bottom: 3px solid #222 !important;
}

#majorPlan .tabBox h4 {
	padding-left: 5px;
	letter-spacing:-0.05em;
}
#majorPlan .input-text {
    box-sizing: border-box;
    width: 95% !important;
    height: 30px !important;
}

#majorPlan select {
	width: 100%;
}
#majorPlan .desc-para {
	margin-top: 10px;
	border: 1px dashed #204b7b;
	color: #204b7b;
	padding: 14px;
	background-color: #f2f2f2;
	font-style: italic;
  		font-weight: 700;
  		line-height: 120%;
}


.box_txt {font-size: 14px; line-height: 160%; letter-spacing: -0.03em; padding: 15px; border: 1px dashed #204b7b; color: #204b7b; background: #f4f4f4; font-family:'NotoKR-Regular', Sans-serif;}

#majorPlan input[type="checkbox"] {
  	cursor: pointer;
    height: 15px;
    width: 15px; color: #ddd;
}

/*왼쪽 메뉴 scroll 수정*/
.lnb{
  position: sticky !important;
  top: 0rem;
}

.sub-container {
	overflow: auto !important;
}


/* menu_tab */
.menu_tab {width:100%; box-sizing:border-box; z-index: 99;}
.menu_tab ul{margin:0 auto; overflow:hidden; }
.menu_tab li {float:left; display:block; height:45px; line-height:45px; font-size:16px; color: #333; letter-spacing:0pt; text-align:center;   
background-color:#F2F6FE; box-sizing:border-box; border-radius:5px 5px 0 0; border-top:1px solid #AABDDE; border-right:1px solid #AABDDE; transition:all 0.3s; cursor:pointer;}
.menu_tab li:first-child {border-left:1px solid #AABDDE;}
.menu_tab li.active	{display:block; color:#fff; font-weight:700; text-decoration: none; background:#768DB6; border-top:1px solid #768DB6; border-right:1px solid #AABDDE; transition:all 0.3s;}
.menu_tab li.active:first-child {border-left:1px solid #768DB6;}

.menu_tab ul.tab_2 li {width:50%}
.menu_tab ul.tab_3 li {width:33.33%}
.menu_tab ul.tab_4 li {width:25%}
.menu_tab ul.tab_5 li {width:20%}
.menu_tab ul.tab_6 li {width:16.66%}
.menu_tab ul.tab_7 li {width:14.28%}
.menu_tab ul.tab_8 li {width:12.5%}
.menu_tab ul.tab_9 li {width:11.1%}

h3 .subScript {position:relative;top:10px;float:right;font-size:13px;}
	
/* 검증완료,미검증 */
.gb_ico1_1	{padding: 2px; border-radius: 2px; background: #7cb737; color: #fff; font-size:12px; font-weight: normal; line-height: 100%; white-space: nowrap;}
.gb_ico1_2	{padding: 2px; border-radius: 2px; background: #ff5722; color: #fff; font-size:12px; font-weight: normal; line-height: 100%; white-space: nowrap;}

/* 테이블 사선처리 */
	.diagonal {
		background-image: linear-gradient(to left bottom, transparent calc(50% - 1px), #dedede, transparent calc(50% + 1px)) !important;
		background-size: 120% 120% !important;
		background-position: center !important;
	}
	
	
	.bigRadio {
        vertical-align: middle;
        appearance: none;
        border: max(1px, 0.1em) solid #999;
        border-radius: 50%;
        width: 1.75em;
        height: 1.75em;
}
.bigRadio:checked {
        border: 0.4em solid tomato;
}