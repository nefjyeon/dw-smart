	#wrapPop1 h3{padding-bottom: 1px;font-size:15px;color: #222222;font-family:"NotoKR-Regular", Sans-serif; }
	#wrapPop1 h4{padding-bottom:10px;font-size:13px;color: #222222;font-family:"NotoKR-Regular", Sans-serif; }
	#wrapPop1 h5{padding-bottom:10px;font-size:12px;color: #222222;font-family:"NotoKR-Regular", Sans-serif; }
	#wrapPop1 table.bodyTbl{width:100%;border-top:2px solid #222;border-bottom:1px solid #222;}
	#wrapPop1 table.bodyTbl tbody tr th{padding:5px;font-size:12px;line-height:13px;background:#f0f0f0;}
	#wrapPop1 table.bodyTbl tbody tr td{padding:5px;font-size:12px;line-height:13px;text-align:center;}
	#wrapPop1 table.bodyTbl tbody tr td.right{text-align:right;}
 	#wrapPop1 table.headTbl tbody tr td{vertical-align:middle;text-align:center;color:#555555;font-size:11px;height:13px;}
	#wrapPop1 div.tabBox{padding-bottom:20px;position:relative;}
	#wrapPop1 table.headTbl tr th{font-size:11px;color:#222222;text-align:center;vertical-align:middle;background:#f0f0f0;}
	#wrapPop1 table th{padding: 0px 0px;}
	#wrapPop1 table td{padding: 0px 0px;}

