.bot div div:nth-child(1){margin-left:0px;}
.bot p{margin-top:40px;padding-bottom:20px;font-size:25px;color:#274992;font-family:'NotoKR-Medium', sans-serif;font-weight:600;letter-spacing: -0.5px; }
.bot p:before { content:''; display:block; position:relative; left:0; right:0; top:0px; width:35px; height:3px; margin:0 auto; background:#274992;border-radius: 50px;  }
