}


	table.headTbl tbody tr td a{color:#333;}
	table.headTbl tbody tr{ border-top:1px solid #d5d5d5;}
	table.headTbl tfoot tr td{text-align:center;color:#fff;border-top:1px solid #d5d5d5;background:#aeaeae;}

	table.headTbl.btnRitTbl{margin-bottom:0;}
	table.headTbl.btnRitTbl tbody tr td{position:relative;}
	table.headTbl.btnRitTbl tbody tr td.btn a{position:absolute;top:14px;right:0;}

	table.abilDataTbl{margin-bottom:0;}
	table.abilTbl{margin-bottom:10px;}
	table.abilTbl tr th+th{border-left:1px solid #d5d5d5;}
	table.abilTbl tr th+td{border-left:1px solid #dedede;}
	table.abilTbl tr td+td{border-left:1px solid #dedede;}
	table.abilTbl tr td+th{border-left:1px solid #dedede;}
	table.abilTbl tfoot tr td{text-align:center;color:#fff;border-top:1px solid #d5d5d5;background:#aeaeae}
	table.abilTbl tfoot tr.evalTfoot td{background:#E1E1D6;color:#000;}

	table.headTbl.widTbl{margin-bottom:0;border-bottom:0;table-layout: fixed;}
	table.headTbl.widTbl thead tr th{line-height:20px;}
	table.headTbl.abilTbl.widTbl tbody tr td{font-size:12px;}
	table.headTbl.abilTbl tbody tr td{padding-top:15px; padding-bottom: 15px; font-size:14px;color:#222222;vertical-align:middle;border-bottom:1px solid #d5d5d5; border-left:1px solid #dedede; border-right:1px solid #dedede;}

	table.bodyTbl{width:100%;border-top:2px solid #222;border-bottom:1px solid #222;}
	table.bodyTbl thead tr th{font-size:14px;background:#f6f6f6;font-family: 'NotoKR-Medium', sans-serif; font-weight: 500; }
	table.bodyTbl thead tr .underline{border-bottom:1px solid #d5d5d5;}
	table.bodyTbl tbody tr th{font-size:14px;line-height:18px;background:#f6f6f6;font-family: 'NotoKR-Medium', sans-serif; font-weight: 500; }
	table.bodyTbl tbody tr th.th-low {background-color: #fff;}
	table.bodyTbl tbody tr td{font-size:14px;line-height:24px; padding-left: 7px; padding-right: 7px;}
	table.bodyTbl tbody tr td p{padding-top:5px; padding-bottom: 5px;}
	table.bodyTbl tbody.noPaddingW tr td{padding-left:0;pading-right:0;}
	table.bodyTbl tbody tr.noPaddingW td{padding-left:0;pading-right:0;}
	table.bodyTbl tbody tr td.noPaddingW{padding-left:0;pading-right:0;}
	table.bodyTbl tbody tr td {text-align:left;}
	table.bodyTbl tbody tr td.right{text-align:right;}
	table.bodyTbl tbody tr td.textTd{text-align:left;}
	table.bodyTbl tbody tr td.textTd textarea{height:150px;font-size:13px;line-height:20px;border:1px solid #d5d5d5;}
	table.bodyTbl tbody tr td.evalsum{}
	table.bodyTbl tbody tr td.evalsum input{border:none;text-align:center;}
	table.bodyTbl tbody tr.font13 td{font-size:13px;padding-left:6px;padding-right:6px;}
	table.bodyTbl tbody tr td .checked{min-height:40px;}

	table.bodyTbl.addTbl tbody tr th{text-align:left;}
	table.bodyTbl.addTbl tbody tr th strong{padding-top:5px;float:left;}
	table.bodyTbl.addTbl tbody tr th a.addBtn{float:right;}
	table.bodyTbl tbody tr td.addBox{text-align:left;}
	table.bodyTbl tbody tr td.addBox p+p{padding-top:10px;}

	table.bodyTbl.borNo{border-top:0;}
	table.bodyTbl.apprTbl{table-layout: fixed;}
	table.bodyTbl.apprTbl tbody tr th{text-align:left;}
	table.bodyTbl.apprTbl tbody tr th a{float:right;}
	table.bodyTbl.apprTbl tfoot tr td{text-align:center;color:#fff;border-top:1px solid #d5d5d5;background:#aeaeae;}

	table.subTbl {width:100%; border: 0; margin: 0;border-top:2px solid #222;}
	table.subTbl tr:last-child {border-bottom:0px;}
	table.subTbl > tbody > tr {border-top: 0;}
	table.subTbl > tbody > tr+tr {border-top: 1px solid #d5d5d5;}
	table.subTbl > tbody > tr.view{border-top-width: 0px;}

	table.innerTbl {width:100%; border: 0; margin-right: -1px; margin-bottom: -1px;}
	table.innerTbl td:last-child {border-right:none;}
	table.innerTbl tr:last-child {border-bottom:none;}
	table.innerTbl > tbody > tr {border-top: 0;}
	table.innerTbl > tbody > tr+tr {border-top: 1px solid #d5d5d5;}
	
	table.smallTbl tbody tr th{font-size: 12px;}
	table.smallTbl tbody tr td, table.smallTbl tbody tr th{padding: 5px;}

	table.topLine{border-top:2px solid #222;}
	table.thinTopLine{border-top:1px solid #222;}
	table.noTopLine{border-top:0px;margin-bottom:0px}
	table.noBottomLine{border-bottom:0px;}
	table.noBottomMargin{margin-bottom:0px}
	table tr th.ritBor{border-right:1px solid #d5d5d5;}
	table tbody tr td.noData{padding:100px 0; text-align:center;}

	.addTxtTbl tbody tr td textarea{height:30px;}
	.addTxtTbl tbody tr td p a{margin-left:5px;vertical-align:top;}
	.addTxtTbl tbody tr td p+p a{vertical-align:middle;}


table.subTbl {width:100%; border: 0; margin-right: -1px; margin-bottom: -1px;}
table.subTbl tr:last-child {border-bottom:0px;}
table.subTbl > tbody > tr {border-top: 0;margin-left: -1px;}
table.subTbl > tbody > tr+tr {border-top: 1px solid #d5d5d5;}
