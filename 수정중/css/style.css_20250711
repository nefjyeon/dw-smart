	#wrapPop table.bodyTbl{width:100%;border-top:2px solid #222;border-bottom:1px solid #222;}
	#wrapPop table.bodyTbl tbody tr th{padding:5px;font-size:12px;line-height:13px;background:#f0f0f0;}
	#wrapPop table.bodyTbl tbody tr td{padding:5px;font-size:12px;line-height:13px;text-align:center;}
	#wrapPop table.bodyTbl tbody tr td.right{text-align:right;}
 	#wrapPop table.headTbl tbody tr td{vertical-align:middle;text-align:center;color:#555555;font-size:12px;height:13px;}
	#wrapPop div.tabBox{padding-bottom:20px;position:relative;}
	#wrapPop table.headTbl tr th{font-size:11px;color:#222222;text-align:center;vertical-align:middle;background:#f0f0f0;}
	#wrapPop table th{padding: 3px 10px;}
	#wrapPop table td{padding: 3px 10px;}

